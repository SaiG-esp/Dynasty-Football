# Copy this file to .env and fill in your own values.

# CollegeFootballData API key. Get a free one at https://collegefootballdata.com/key
CFBD_API_KEY=your_cfbd_api_key_here

# PostgreSQL connection (used by main.py and matchup_data3.py).
# Defaults below match a local dev Postgres with a passwordless "jarvis" role.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=jarvis
DB_PASSWORD=

# Comma-separated list of origins main.py's CORS middleware should allow.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
